# API
API_PORT=8080
ASPNETCORE_ENVIRONMENT=Development

# PostgreSQL
POSTGRES_PORT=5432
POSTGRES_DB=authcore
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=root
DATABASE__REDIS__KEYPREFIX=authcore:dev

# RabbitMQ
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=root
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ__EMAILQUEUE=authcore.email
RABBITMQ__DEADLETTERQUEUE=authcore.email.dlq