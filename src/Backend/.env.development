# API
API_PORT=8080
ASPNETCORE_ENVIRONMENT=Development

# PostgreSQL
POSTGRES_PORT=5432
POSTGRES_DB=auth_core
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=root
REDIS_KEY_PREFIX=authcore:dev

# RabbitMQ
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=root
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_EMAIL_QUEUE=authcore.email
