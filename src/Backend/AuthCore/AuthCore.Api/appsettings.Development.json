{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "PostgreSql": "Host=localhost;Port=5432;Database=auth_core;Username=postgres;Password=root;Pooling=true"
  },
  "Database": {
    "Migrations": {
      "AutoMigrateOnStartup": true,
      "EnsureDatabaseCreated": true,
      "AdminDatabase": "postgres"
    }
  },
  "Authentication": {
    "Jwt": {
      "Issuer": "authcore-dev",
      "Audience": "authcore-dev",
      "SigningKey": "12345678901234567890123456789012",
      "AccessTokenLifetimeMinutes": 15,
      "RefreshTokenLifetimeDays": 7,
      "ClockSkewSeconds": 60
    }
  },
  "Redis": {
    "ConnectionString": "localhost:6379,password=root,abortConnect=false",
    "KeyPrefix": "authcore:dev"
  },
  "Auth": {
    "Cookie": {
      "SessionCookieName": "sid",
      "Secure": false
    },
    "Session": {
      "TtlMinutes": 120,
      "SlidingTtl": true
    }
  },
  "RabbitMq": {
    "Host": "localhost",
    "Port": 5672,
    "Username": "guest",
    "Password": "root",
    "EmailVerificationQueue": "authcore.email"
  }
}
